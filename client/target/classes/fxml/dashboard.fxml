<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.view.DashboardViewController"
            style="-fx-background-color: #0a0f1a;">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0d1520; -fx-border-color: #1e3a52; -fx-border-width: 0 0 1 0; -fx-padding: 0 24;">
            <Label text="ThermaControl"
                   style="-fx-text-fill: #e8f4fd; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Georgia'; -fx-padding: 16 24 16 0;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Dashboard" onAction="#showDashboard"
                    style="-fx-background-color: #1e3a52; -fx-text-fill: #7ab3cc; -fx-border-color: transparent; -fx-padding: 10 18; -fx-cursor: hand; -fx-background-radius: 6;"/>
            <Button text="Alarm Log" onAction="#showAlarmLog"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a8fa8; -fx-border-color: transparent; -fx-padding: 10 18; -fx-cursor: hand;"/>
            <Button text="Configuration" onAction="#showConfig"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a8fa8; -fx-border-color: transparent; -fx-padding: 10 18; -fx-cursor: hand;"/>
            <Button text="Performance" onAction="#showPerformance"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a8fa8; -fx-border-color: transparent; -fx-padding: 10 18; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #5a8fa8; -fx-border-color: transparent; -fx-padding: 10 18; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <HBox spacing="0">

            <!-- SIDEBAR -->
            <VBox spacing="12" minWidth="280" maxWidth="280"
                  style="-fx-background-color: #0d1520; -fx-border-color: #1e3a52; -fx-border-width: 0 1 0 0; -fx-padding: 20;">
                <Label text="Heat Pumps" style="-fx-text-fill: #7ab3cc; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="searchField" promptText="Search pumps..."
                           style="-fx-background-color: #1a2535; -fx-text-fill: #e8f4fd; -fx-prompt-text-fill: #3a5a72; -fx-border-color: #1e3a52; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                <ListView fx:id="pumpListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                <HBox spacing="8">
                    <Button text="+ Add" onAction="#handleAddPump" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #1e5a8a; -fx-text-fill: white; -fx-padding: 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Remove" onAction="#handleRemovePump" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #3a1a1a; -fx-text-fill: #e05a5a; -fx-padding: 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- MAIN PANEL -->
            <VBox spacing="20" HBox.hgrow="ALWAYS"
                  style="-fx-padding: 24; -fx-background-color: #0a0f1a;">

                <!-- PUMP HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4">
                        <Label fx:id="pumpNameLabel" text="Select a pump"
                               style="-fx-text-fill: #e8f4fd; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label fx:id="pumpIdLabel" text=""
                               style="-fx-text-fill: #5a8fa8; -fx-font-size: 13px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text=""
                           style="-fx-text-fill: #4caf50; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #0d2a1a; -fx-padding: 6 14; -fx-background-radius: 20;"/>
                </HBox>

                <!-- METRICS ROW -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-border-color: #1e3a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                        <Label text="WATER FLOW" style="-fx-text-fill: #5a8fa8; -fx-font-size: 11px;"/>
                        <Label fx:id="waterflowLabel" text="—"
                               style="-fx-text-fill: #7ab3cc; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="L/min" style="-fx-text-fill: #3a5a72; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-border-color: #1e3a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                        <Label text="TEMPERATURE" style="-fx-text-fill: #5a8fa8; -fx-font-size: 11px;"/>
                        <Label fx:id="tempLabel" text="—"
                               style="-fx-text-fill: #7ab3cc; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="°C" style="-fx-text-fill: #3a5a72; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-border-color: #1e3a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                        <Label text="ENERGY" style="-fx-text-fill: #5a8fa8; -fx-font-size: 11px;"/>
                        <Label fx:id="energyLabel" text="—"
                               style="-fx-text-fill: #7ab3cc; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="kWh" style="-fx-text-fill: #3a5a72; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #111827; -fx-border-color: #1e3a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                        <Label text="COP" style="-fx-text-fill: #5a8fa8; -fx-font-size: 11px;"/>
                        <Label fx:id="copLabel" text="—"
                               style="-fx-text-fill: #7ab3cc; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="coefficient" style="-fx-text-fill: #3a5a72; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- CHART -->
                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #111827; -fx-border-color: #1e3a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                    <Label text="Water Flow History" style="-fx-text-fill: #7ab3cc; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0 0 8 0;"/>
                    <LineChart fx:id="waterflowChart" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent;">
                        <xAxis><CategoryAxis style="-fx-tick-label-fill: #5a8fa8;"/></xAxis>
                        <yAxis><NumberAxis style="-fx-tick-label-fill: #5a8fa8;"/></yAxis>
                    </LineChart>
                </VBox>

                <!-- ALARM BOX -->
                <VBox spacing="8"
                      style="-fx-background-color: #1a1020; -fx-border-color: #3a1a52; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1; -fx-padding: 16;">
                    <Label text="ACTIVE ALARMS" style="-fx-text-fill: #a05ab3; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="alarmLabel" text="No alarms"
                           style="-fx-text-fill: #c8a8d8; -fx-font-size: 13px;" wrapText="true"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
